# Your Sentry DSN (from your Sentry account)
VITE_SENTRY_DSN=

# Your Sentry organization (from your Sentry account)
VITE_SENTRY_ORG=

# Your Sentry project (from your Sentry account)
VITE_SENTRY_PROJECT=

# Same origin as SERVER_URL in production (Better Auth client baseURL)
VITE_SERVER_URL=

# Your Sentry authentication token (from your Sentry account)
SENTRY_AUTH_TOKEN=
ANTHROPIC_API_KEY=
DATABASE_URL=
RESEND_API_KEY=
BETTER_AUTH_SECRET=
VERCEL_API_KEY=

# Telegram bot — leave empty if TMA / bot is not needed
BOT_TOKEN=
# Bot username without @ (e.g. my_bot) — enables the Telegram plugin when set together with BOT_TOKEN
TELEGRAM_BOT_USERNAME=
# Bot username for t.me/<username> links on the frontend
VITE_TELEGRAM_BOT_USERNAME=
# Required only for OIDC / Login Widget flow — get from https://oauth.telegram.org
TELEGRAM_OIDC_CLIENT_SECRET=

# Google OAuth — leave empty if not needed
# Create OAuth 2.0 Web Client at https://console.cloud.google.com
# Add {SERVER_URL}/api/auth/callback/google as Authorized redirect URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
